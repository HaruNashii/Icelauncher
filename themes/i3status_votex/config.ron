// ╭─────────────────────────────────────────────────────────────────────────╮
// │   I 3 S T A T U S   V O T E X   ·   ICELAUNCHER                         │
// │   Ultra-compact. Pure black. Left top-corner. dwm aesthetic.            │
// ╰─────────────────────────────────────────────────────────────────────────╯
//
//  PALETTE — Votex / i3status
//    Void (0,0,0)  Deep Slate (10,12,22)  Grid Purple (28,14,45)
//    Blue accent (45,90,195)  Hover (35,42,65)  Text (200,210,235)
//    Muted red (200,80,100)
//
//  LAYOUT — COMPACT TOP-LEFT
//    · 420×500 — narrow and tall, just a compact list
//    · TopLeft anchor — like an i3status dropdown at top left
//    · 1 column, 0px entry spacing — dense like a terminal app list
//    · 0px radius everywhere
//    · Search at Top. No footer.

LauncherConfig
(
    window:
    (
        width:              420,
        height:             500,
        max_results:        16,
        padding:            8,
        section_spacing:    0,
        entry_spacing:      0,
        grid_side_items:    1,
        grid_column_spacing: 0,

        border_radius:      (0.0, 0.0, 0.0, 0.0),
        border_width:       1.0,
        border_color:       RGB((45, 55, 100)),
        background_color:   RGBA((10, 12, 22, 100)),
        background_gradient: None,

        shadow_color:       RGBA((0, 0, 0, 0)),
        shadow_offset_x:    0.0,
        shadow_offset_y:    0.0,
        shadow_blur:        0.0,

        anchor:             TopLeft,
        margin_top:         25,
        margin_bottom:      0,
        margin_left:        0,
        margin_right:       0,
    ),

    scrollbar:
    (
        show:                    true,
        width:                   4,
        margin:                  1,
        scroller_width:          4,
        border_radius:           (0.0, 0.0, 0.0, 0.0),
        rail_color:              RGBA((0, 0, 0, 0)),
        rail_border_color:       RGBA((0, 0, 0, 0)),
        rail_border_width:       0.0,
        scroller_color:          RGBA((45, 90, 195, 50)),
        scroller_hovered_color:  RGBA((45, 90, 195, 75)),
        scroller_dragging_color: RGBA((45, 90, 195, 95)),
        scroller_border_color:   RGBA((0, 0, 0, 0)),
        scroller_border_width:   0.0,
    ),

    search:
    (
        placeholder:               "search...",
        text_size:                 11,
        input_padding:             6,
        bottom_margin:             4.0,

        background_color:          RGB((0, 0, 0)),
        background_gradient:       None,
        focused_background_color:  RGB((0, 0, 0)),
        focused_background_gradient: None,
        border_color:              RGB((45, 55, 100)),
        focused_border_color:      RGB((45, 90, 195)),
        border_width:              1.0,
        border_radius:             (0.0, 0.0, 0.0, 0.0),

        text_color:                RGB((200, 210, 235)),
        placeholder_color:         RGB((35, 42, 65)),
        selection_color:           RGBA((45, 90, 195, 45)),

        icon:                      "",
        icon_color:                RGB((35, 42, 65)),

        font_weight:               Normal,
        font_style:                Normal,
        font_family:               "",

        position:                  Top,
        orientation:               Horizontal,
        width:                     0,
        height:                    0,
        fixed_x:                   None,
        fixed_y:                   None,
    ),

    entry:
    (
        name_size:              11,
        name_color:             RGB((200, 210, 235)),
        selected_name_color:    RGB((255, 255, 255)),
        hovered_name_color:     RGB((255, 255, 255)),
        name_font_weight:       Normal,
        name_font_style:        Normal,
        name_font_family:       "",
        name_align:             Left,
        name_max_chars:         55,

        comment_size:           10,
        comment_color:          RGB((35, 42, 65)),
        selected_comment_color: RGB((100, 150, 230)),
        hovered_comment_color:  RGB((35, 42, 65)),
        comment_font_weight:    Normal,
        comment_font_style:     Normal,
        comment_font_family:    "",
        comment_align:          Left,
        comment_max_chars:      55,
        show_comment:           false,
        name_comment_spacing:   1,

        padding:                (3, 8, 3, 8),
        label_position:         Right,
        width:                  0,
        height:                 0,

        background_color:       RGBA((0, 0, 0, 0)),
        hovered_color:          RGB((35, 42, 65)),
        pressed_color:          RGB((15, 18, 30)),
        selected_color:         RGBA((45, 90, 195, 35)),
        selected_hovered_color: RGBA((45, 90, 195, 55)),
        text_color:             RGB((200, 210, 235)),

        border_color:           RGBA((0, 0, 0, 0)),
        selected_border_color:  RGBA((45, 90, 195, 60)),
        hovered_border_color:   RGBA((0, 0, 0, 0)),
        pressed_border_color:   RGBA((0, 0, 0, 0)),
        border_width:           0.0,
        border_radius:          (0.0, 0.0, 0.0, 0.0),

        shadow_color:               RGBA((0, 0, 0, 0)),
        shadow_offset_x:            0.0,
        shadow_offset_y:            0.0,
        shadow_blur:                0.0,
        selected_shadow_color:      RGBA((0, 0, 0, 0)),
        selected_shadow_offset_x:   0.0,
        selected_shadow_offset_y:   0.0,
        selected_shadow_blur:       0.0,
        hovered_shadow_color:       RGBA((0, 0, 0, 0)),
        hovered_shadow_offset_x:    0.0,
        hovered_shadow_offset_y:    0.0,
        hovered_shadow_blur:        0.0,

        wrap_word:                      false,
        ellipsize_instead_of_wrapping:   true,
        ellipsis:                       "...",

        show_separator:     true,
        separator_color:    RGB((15, 18, 30)),
        separator_width:    1.0,
    ),

    icon:
    (
        show:                  true,
        use_real_icons:        true,
        width:                 20,
        height:                20,
        text_size:             10,
        gap:                   6,
        padding:               (0, 0),
        opacity:               0.8,
        selected_opacity:      1.0,
        hovered_opacity:       1.0,

        background_color:      RGBA((0, 0, 0, 0)),
        hovered_color:         RGBA((35, 42, 65, 80)),
        selected_color:        RGBA((45, 90, 195, 50)),
        icon_color:            RGB((100, 130, 200)),
        selected_icon_color:   RGB((255, 255, 255)),
        hovered_icon_color:    RGB((150, 180, 255)),

        border_color:          RGBA((0, 0, 0, 0)),
        selected_border_color: RGBA((0, 0, 0, 0)),
        hovered_border_color:  RGBA((0, 0, 0, 0)),
        border_width:          0.0,
        border_radius:         (3.0, 3.0, 3.0, 3.0),
    ),

    footer:
    (
        show:             false,
        show_hint:        false,
        hint_text:        "",
        show_count:       false,
        count_format:     "{shown} / {total}",
        single_format:    "{total}",
        text_size:        10,
        text_color:       RGB((35, 42, 65)),
        hint_color:       RGB((35, 42, 65)),
        count_color:      RGB((45, 90, 195)),
        font_weight:      Normal,
        font_style:       Normal,
        top_margin:       4.0,
        padding:          (0, 0, 0, 0),
        background_color: RGBA((0, 0, 0, 0)),
        border_color:     RGBA((0, 0, 0, 0)),
        border_width:     0.0,
        border_radius:    (0.0, 0.0, 0.0, 0.0),
        position:         Bottom,
        text_orientation: Horizontal,
        width:            0,
        height:           0,
    ),

    behaviour:
    (
        search_name:        true,
        search_comment:     true,
        search_exec:        false,
        search_keywords:    true,
        case_sensitive:     false,
        close_on_launch:    true,
        terminal_command:   "",
        calc_enabled:           true,
        copy_feedback_text:     "Copied!",
        copy_feedback_seconds:  2.0,
        min_query_length:       0,
        show_on_empty_query:    true,
        max_empty_results:      0,
    ),

    keybinds:
    (
        close:              ["Escape"],
        select_up:          ["ArrowUp"],
        select_down:        ["ArrowDown"],
        select_left:        ["ArrowLeft"],
        select_right:       ["ArrowRight", "Tab"],
        launch_alt_prefix:  "Alt",
        relaunch_key:       "l",
    ),

    background_images: [],
)
