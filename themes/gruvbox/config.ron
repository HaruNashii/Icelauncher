// ╭─────────────────────────────────────────────────────────────────────────╮
// │                                                                         │
// │   G R U V B O X   ·   ICELAUNCHER                                       │
// │   Retro groove. Warm earthy tones. Classic list. Left-side search.      │
// │                                                                         │
// ╰─────────────────────────────────────────────────────────────────────────╯
//
//  PALETTE — Gruvbox Dark Hard
//
//    bg0_h   ( 29,  32,  33)  ← window background (darkest)
//    bg0     ( 40,  40,  40)  ← entry background
//    bg1     ( 60,  56,  54)  ← hover
//    bg2     ( 80,  73,  69)  ← pressed / scrollbar
//    fg1     (235, 219, 178)  ← primary text
//    fg3     (189, 174, 147)  ← secondary text / placeholder
//    yellow  (250, 189,  47)  ← primary accent (search border, selected)
//    orange  (254, 128,  25)  ← hover accent
//    aqua    (142, 192, 124)  ← icon glyph / count
//    purple  (211, 134, 155)  ← icon selected
//    red     (251,  73,  52)  ← muted/error
//
//  DESIGN:
//    · Classic list (grid_side_items: 1) — Gruvbox doesn't do grids
//    · Search bar on the LEFT side, vertically oriented — typewriter aesthetic
//    · Sharp corners (4px radius) — matches Gruvbox's no-nonsense identity
//    · Full-width window — bar-like, intentionally wide
//    · Yellow is the only accent — golden warmth, one ruler
//    · Footer shows both hint and count — retro info-dense feel

LauncherConfig
(

    // ─────────────────────────────────────────────────────────────────────────
    //  WINDOW
    // ─────────────────────────────────────────────────────────────────────────
    window:
    (
        width:              640,
        height:             440,
        max_results:        10,
        padding:            10,
        section_spacing:    4,
        entry_spacing:      2,
        grid_side_items:    1,

        border_radius:      (4.0, 4.0, 4.0, 4.0),
        border_width:       1.0,
        border_color:       RGB((80, 73, 69)),
        background_color:   RGBA((29, 32, 33, 98)),

        shadow_color:       RGBA((0, 0, 0, 80)),
        shadow_offset_x:    0.0,
        shadow_offset_y:    6.0,
        shadow_blur:        18.0,
    ),


    // ─────────────────────────────────────────────────────────────────────────
    //  SCROLLBAR
    // ─────────────────────────────────────────────────────────────────────────
    scrollbar:
    (
        show:                   true,
        width:                  6,
        margin:                 2,
        scroller_width:         6,
        border_radius:          (2.0, 2.0, 2.0, 2.0),

        rail_color:             RGBA((80, 73, 69, 40)),
        rail_border_color:      RGBA((0, 0, 0, 0)),
        rail_border_width:      0.0,

        scroller_color:         RGBA((250, 189, 47, 70)),
        scroller_border_color:  RGBA((0, 0, 0, 0)),
        scroller_border_width:  0.0,
    ),


    // ─────────────────────────────────────────────────────────────────────────
    //  SEARCH BAR
    // ─────────────────────────────────────────────────────────────────────────
    search:
    (
        placeholder:        "grep apps...",
        text_size:          14,
        input_padding:      10,
        bottom_margin:      8.0,

        background_color:   RGB((40, 40, 40)),
        border_color:       RGB((250, 189, 47)),
        border_width:       1.5,
        border_radius:      (4.0, 4.0, 4.0, 4.0),

        text_color:         RGB((235, 219, 178)),
        placeholder_color:  RGB((124, 111, 100)),
        selection_color:    RGB((250, 189, 47)),

        position:           Left,
        orientation:        Vertical,
        width:              42,
        height:             0,
        fixed_x:            None,
        fixed_y:            None,
    ),


    // ─────────────────────────────────────────────────────────────────────────
    //  RESULT ENTRIES
    // ─────────────────────────────────────────────────────────────────────────
    entry:
    (
        name_size:              14,
        name_color:             RGB((235, 219, 178)),

        comment_size:           11,
        comment_color:          RGB((189, 174, 147)),
        comment_max_chars:      60,
        show_comment:           true,

        padding:                (7, 12),

        background_color:       RGBA((40, 40, 40, 50)),
        hovered_color:          RGB((60, 56, 54)),
        pressed_color:          RGB((80, 73, 69)),
        selected_color:         RGBA((250, 189, 47, 12)),
        selected_hovered_color: RGBA((254, 128, 25, 30)),
        text_color:             RGB((235, 219, 178)),

        border_color:           RGBA((80, 73, 69, 50)),
        selected_border_color:  RGB((250, 189, 47)),
        border_width:           1.0,
        border_radius:          (4.0, 4.0, 4.0, 4.0),

        shadow_color:           RGBA((0, 0, 0, 0)),
        shadow_offset_x:        0.0,
        shadow_offset_y:        0.0,
        shadow_blur:            0.0,

        width:                  0,
        height:                 0,
    ),


    // ─────────────────────────────────────────────────────────────────────────
    //  ICON BADGE
    // ─────────────────────────────────────────────────────────────────────────
    icon:
    (
        show:               true,
        use_real_icons:     false,
        width:              30,
        height:             30,
        text_size:          15,
        gap:                10,

        background_color:   RGB((40, 40, 40)),
        selected_color:     RGB((211, 134, 155)),
        icon_color:         RGB((142, 192, 124)),

        border_color:       RGB((80, 73, 69)),
        border_width:       1.0,
        border_radius:      (4.0, 4.0, 4.0, 4.0),
    ),


    // ─────────────────────────────────────────────────────────────────────────
    //  FOOTER
    // ─────────────────────────────────────────────────────────────────────────
    footer:
    (
        show:           true,
        show_hint:      true,
        hint_text:      "↑↓ navigate  •  Enter launch  •  Esc close",
        show_count:     true,
        text_size:      11,
        text_color:     RGB((142, 192, 124)),
        top_margin:     5.0,
        position:       Bottom,
        text_orientation: Horizontal,
        width:          0,
        height:         0,
    ),


    // ─────────────────────────────────────────────────────────────────────────
    //  SEARCH BEHAVIOUR
    // ─────────────────────────────────────────────────────────────────────────
    behaviour:
    (
        search_name:        true,
        search_comment:     true,
        search_exec:        true,
        search_keywords:    true,
        case_sensitive:     false,
        close_on_launch:    true,
        terminal_command:   "",
        calc_enabled:           true,
        copy_feedback_text:     "Yanked!",
        copy_feedback_seconds:  1.5,
    ),

    background_images: [],
)
