// ╭─────────────────────────────────────────────────────────────────────────╮
// │   G O T H P P U C C I N   ·   ICELAUNCHER                               │
// │   Pure black + Mocha pastels. Top-right corner. Sleek dropdown.         │
// ╰─────────────────────────────────────────────────────────────────────────╯
//
//  PALETTE — Gothppuccin (black base + Catppuccin Mocha accents)
//    Black (0,0,0)  Surface0 (49,50,68)  Text (205,214,244)
//    Mauve (203,166,247) ← accent  Pink (245,194,231)  Lavender (180,190,254)
//
//  LAYOUT — TOP-RIGHT DROPDOWN
//    · 440×600 — portrait, like a search dropdown
//    · TopRight anchor — falls from the top-right corner
//    · 1 column, 6px radius — subtle softness on pure black
//    · Search at Top. Footer at Bottom.

LauncherConfig
(
    window:
    (
        width:              440,
        height:             600,
        max_results:        15,
        padding:            12,
        section_spacing:    0,
        entry_spacing:      2,
        grid_side_items:    1,
        grid_column_spacing: 0,

        border_radius:      (0.0, 0.0, 6.0, 6.0),
        border_width:       0.0,
        border_color:       RGBA((0, 0, 0, 0)),
        background_color:   RGB((0, 0, 0)),
        background_gradient: None,

        shadow_color:       RGBA((0, 0, 0, 80)),
        shadow_offset_x:    -4.0,
        shadow_offset_y:    8.0,
        shadow_blur:        24.0,

        anchor:             TopRight,
        margin_top:         0,
        margin_bottom:      0,
        margin_left:        0,
        margin_right:       0,
    ),

    scrollbar:
    (
        show:                    true,
        width:                   4,
        margin:                  2,
        scroller_width:          4,
        border_radius:           (3.0, 3.0, 3.0, 3.0),
        rail_color:              RGBA((0, 0, 0, 0)),
        rail_border_color:       RGBA((0, 0, 0, 0)),
        rail_border_width:       0.0,
        scroller_color:          RGBA((203, 166, 247, 35)),
        scroller_hovered_color:  RGBA((203, 166, 247, 60)),
        scroller_dragging_color: RGBA((203, 166, 247, 80)),
        scroller_border_color:   RGBA((0, 0, 0, 0)),
        scroller_border_width:   0.0,
    ),

    search:
    (
        placeholder:               "Search applications...",
        text_size:                 15,
        input_padding:             10,
        bottom_margin:             8.0,

        background_color:          RGB((10, 10, 16)),
        background_gradient:       None,
        focused_background_color:  RGB((10, 10, 16)),
        focused_background_gradient: None,
        border_color:              RGBA((0, 0, 0, 0)),
        focused_border_color:      RGB((203, 166, 247)),
        border_width:              1.5,
        border_radius:             (6.0, 6.0, 6.0, 6.0),

        text_color:                RGB((205, 214, 244)),
        placeholder_color:         RGB((49, 50, 68)),
        selection_color:           RGBA((203, 166, 247, 40)),

        icon:                      "",
        icon_color:                RGB((49, 50, 68)),

        font_weight:               Normal,
        font_style:                Normal,
        font_family:               "",

        position:                  Top,
        orientation:               Horizontal,
        width:                     0,
        height:                    0,
        fixed_x:                   None,
        fixed_y:                   None,
    ),

    entry:
    (
        name_size:              14,
        name_color:             RGB((205, 214, 244)),
        selected_name_color:    RGB((255, 255, 255)),
        hovered_name_color:     RGB((255, 255, 255)),
        name_font_weight:       Normal,
        name_font_style:        Normal,
        name_font_family:       "",
        name_align:             Left,
        name_max_chars:         45,

        comment_size:           11,
        comment_color:          RGB((49, 50, 68)),
        selected_comment_color: RGB((147, 153, 178)),
        hovered_comment_color:  RGB((49, 50, 68)),
        comment_font_weight:    Normal,
        comment_font_style:     Normal,
        comment_font_family:    "",
        comment_align:          Left,
        comment_max_chars:      45,
        show_comment:           true,
        name_comment_spacing:   2,

        padding:                (5, 10, 5, 10),
        label_position:         Right,
        width:                  0,
        height:                 0,

        background_color:       RGBA((0, 0, 0, 0)),
        hovered_color:          RGB((10, 10, 16)),
        pressed_color:          RGB((0, 0, 0)),
        selected_color:         RGBA((203, 166, 247, 15)),
        selected_hovered_color: RGBA((203, 166, 247, 35)),
        text_color:             RGB((205, 214, 244)),

        border_color:           RGBA((0, 0, 0, 0)),
        selected_border_color:  RGBA((203, 166, 247, 45)),
        hovered_border_color:   RGBA((0, 0, 0, 0)),
        pressed_border_color:   RGBA((0, 0, 0, 0)),
        border_width:           1.0,
        border_radius:          (6.0, 6.0, 6.0, 6.0),

        shadow_color:               RGBA((0, 0, 0, 0)),
        shadow_offset_x:            0.0,
        shadow_offset_y:            0.0,
        shadow_blur:                0.0,
        selected_shadow_color:      RGBA((0, 0, 0, 0)),
        selected_shadow_offset_x:   0.0,
        selected_shadow_offset_y:   0.0,
        selected_shadow_blur:       0.0,
        hovered_shadow_color:       RGBA((0, 0, 0, 0)),
        hovered_shadow_offset_x:    0.0,
        hovered_shadow_offset_y:    0.0,
        hovered_shadow_blur:        0.0,

        wrap_word:                      false,
        ellipsize_instead_of_wrapping:   true,
        ellipsis:                       "...",

        show_separator:     false,
        separator_color:    RGBA((20, 20, 30, 80)),
        separator_width:    1.0,

	show_shortcut_hint: false,
	show_hot_apps:	    false
    ),

    icon:
    (
        show:                  true,
        use_real_icons:        true,
        width:                 34,
        height:                34,
        text_size:             17,
        gap:                   10,
        padding:               (0, 0),
        opacity:               1.0,
        selected_opacity:      1.0,
        hovered_opacity:       1.0,

        background_color:      RGB((10, 10, 16)),
        hovered_color:         RGB((20, 20, 30)),
        selected_color:        RGBA((203, 166, 247, 50)),
        icon_color:            RGB((203, 166, 247)),
        selected_icon_color:   RGB((255, 255, 255)),
        hovered_icon_color:    RGB((203, 166, 247)),

        border_color:          RGBA((0, 0, 0, 0)),
        selected_border_color: RGBA((203, 166, 247, 50)),
        hovered_border_color:  RGBA((0, 0, 0, 0)),
        border_width:          1.0,
        border_radius:         (6.0, 6.0, 6.0, 6.0),
    ),

    footer:
    (
        show:             true,
        show_hint:        false,
        hint_text:        "",
        show_count:       true,
        count_format:     "{shown} / {total} results",
        single_format:    "{total} result",
        text_size:        11,
        text_color:       RGB((49, 50, 68)),
        hint_color:       RGB((49, 50, 68)),
        count_color:      RGB((203, 166, 247)),
        font_weight:      Normal,
        font_style:       Normal,
        top_margin:       6.0,
        padding:          (0, 0, 0, 0),
        background_color: RGBA((0, 0, 0, 0)),
        border_color:     RGBA((0, 0, 0, 0)),
        border_width:     0.0,
        border_radius:    (0.0, 0.0, 0.0, 0.0),
        position:         Bottom,
        text_orientation: Horizontal,
        width:            0,
        height:           0,
    ),

    behaviour:
    (
        search_name:        true,
        search_comment:     true,
        search_exec:        false,
        search_keywords:    true,
        case_sensitive:     false,
        close_on_launch:    true,
        terminal_command:   "",
        calc_enabled:           true,
        copy_feedback_text:     "Copied!",
        copy_feedback_seconds:  2.0,
        min_query_length:       0,
        show_on_empty_query:    true,
        max_empty_results:      0,
    ),

    keybinds:
    (
        close:              ["Escape"],
        select_up:          ["ArrowUp"],
        select_down:        ["ArrowDown"],
        select_left:        ["ArrowLeft"],
        select_right:       ["ArrowRight", "Tab"],
        launch_alt_prefix:  "Alt",
        relaunch_key:       "l",
    ),

    background_images: [],
)

