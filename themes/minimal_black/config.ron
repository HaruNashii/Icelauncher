// ╭─────────────────────────────────────────────────────────────────────────╮
// │   M I N I M A L   B L A C K   ·   ICELAUNCHER                           │
// │   Pure black. Ultra-thin strip. Full-width top. Text only.              │
// ╰─────────────────────────────────────────────────────────────────────────╯
//
//  PALETTE
//    bg (8,8,8)  fg (220,220,220)  dim (120,120,120)
//    accent white (255,255,255)  red (200,80,80)
//
//  LAYOUT — FULL-WIDTH MINI STRIP, TOP
//    · 0×360 (full width) — hairline strip at top of screen
//    · Top anchor, flush
//    · 1 column, no separator, tiny padding
//    · 0px radius everywhere
//    · Search at Top. No footer.

LauncherConfig
(
    window:
    (
        width:              0,
        height:             360,
        max_results:        14,
        padding:            6,
        section_spacing:    0,
        entry_spacing:      0,
        grid_side_items:    1,
        grid_column_spacing: 0,

        border_radius:      (0.0, 0.0, 0.0, 0.0),
        border_width:       0.0,
        border_color:       RGBA((0, 0, 0, 0)),
        background_color:   RGBA((8, 8, 8, 100)),
        background_gradient: None,

        shadow_color:       RGBA((0, 0, 0, 0)),
        shadow_offset_x:    0.0,
        shadow_offset_y:    0.0,
        shadow_blur:        0.0,

        anchor:             Top,
        margin_top:         0,
        margin_bottom:      0,
        margin_left:        0,
        margin_right:       0,
    ),

    scrollbar:
    (
        show:                    false,
        width:                   3,
        margin:                  1,
        scroller_width:          3,
        border_radius:           (0.0, 0.0, 0.0, 0.0),
        rail_color:              RGBA((0, 0, 0, 0)),
        rail_border_color:       RGBA((0, 0, 0, 0)),
        rail_border_width:       0.0,
        scroller_color:          RGBA((100, 100, 100, 50)),
        scroller_hovered_color:  RGBA((140, 140, 140, 70)),
        scroller_dragging_color: RGBA((180, 180, 180, 90)),
        scroller_border_color:   RGBA((0, 0, 0, 0)),
        scroller_border_width:   0.0,
    ),

    search:
    (
        placeholder:               "[ search ]",
        text_size:                 11,
        input_padding:             6,
        bottom_margin:             4.0,

        background_color:          RGB((8, 8, 8)),
        background_gradient:       None,
        focused_background_color:  RGB((16, 16, 16)),
        focused_background_gradient: None,
        border_color:              RGBA((0, 0, 0, 0)),
        focused_border_color:      RGB((255, 255, 255)),
        border_width:              1.0,
        border_radius:             (0.0, 0.0, 0.0, 0.0),

        text_color:                RGB((255, 255, 255)),
        placeholder_color:         RGB((60, 60, 60)),
        selection_color:           RGBA((255, 255, 255, 30)),

        icon:                      "",
        icon_color:                RGB((60, 60, 60)),

        font_weight:               Normal,
        font_style:                Normal,
        font_family:               "",

        position:                  Top,
        orientation:               Horizontal,
        width:                     0,
        height:                    0,
        fixed_x:                   None,
        fixed_y:                   None,
    ),

    entry:
    (
        name_size:              11,
        name_color:             RGB((220, 220, 220)),
        selected_name_color:    RGB((255, 255, 255)),
        hovered_name_color:     RGB((255, 255, 255)),
        name_font_weight:       Normal,
        name_font_style:        Normal,
        name_font_family:       "",
        name_align:             Left,
        name_max_chars:         80,

        comment_size:           10,
        comment_color:          RGB((60, 60, 60)),
        selected_comment_color: RGB((120, 120, 120)),
        hovered_comment_color:  RGB((60, 60, 60)),
        comment_font_weight:    Normal,
        comment_font_style:     Normal,
        comment_font_family:    "",
        comment_align:          Left,
        comment_max_chars:      80,
        show_comment:           false,
        name_comment_spacing:   1,

        padding:                (2, 8, 2, 8),
        label_position:         Right,
        width:                  0,
        height:                 0,

        background_color:       RGBA((0, 0, 0, 0)),
        hovered_color:          RGB((22, 22, 22)),
        pressed_color:          RGB((8, 8, 8)),
        selected_color:         RGB((255, 255, 255)),
        selected_hovered_color: RGB((220, 220, 220)),
        text_color:             RGB((220, 220, 220)),

        border_color:           RGBA((0, 0, 0, 0)),
        selected_border_color:  RGBA((0, 0, 0, 0)),
        hovered_border_color:   RGBA((0, 0, 0, 0)),
        pressed_border_color:   RGBA((0, 0, 0, 0)),
        border_width:           0.0,
        border_radius:          (0.0, 0.0, 0.0, 0.0),

        shadow_color:               RGBA((0, 0, 0, 0)),
        shadow_offset_x:            0.0,
        shadow_offset_y:            0.0,
        shadow_blur:                0.0,
        selected_shadow_color:      RGBA((0, 0, 0, 0)),
        selected_shadow_offset_x:   0.0,
        selected_shadow_offset_y:   0.0,
        selected_shadow_blur:       0.0,
        hovered_shadow_color:       RGBA((0, 0, 0, 0)),
        hovered_shadow_offset_x:    0.0,
        hovered_shadow_offset_y:    0.0,
        hovered_shadow_blur:        0.0,

        wrap_word:                      false,
        ellipsize_instead_of_wrapping:   true,
        ellipsis:                       "...",

        show_separator:     false,
        separator_color:    RGBA((30, 30, 30, 80)),
        separator_width:    1.0,

	show_hot_apps:     false
    ),

    icon:
    (
        show:                  true,
        use_real_icons:        true,
        width:                 18,
        height:                18,
        text_size:             9,
        gap:                   6,
        padding:               (0, 0),
        opacity:               0.7,
        selected_opacity:      1.0,
        hovered_opacity:       1.0,

        background_color:      RGBA((0, 0, 0, 0)),
        hovered_color:         RGBA((255, 255, 255, 10)),
        selected_color:        RGBA((0, 0, 0, 0)),
        icon_color:            RGB((100, 100, 100)),
        selected_icon_color:   RGB((0, 0, 0)),
        hovered_icon_color:    RGB((180, 180, 180)),

        border_color:          RGBA((0, 0, 0, 0)),
        selected_border_color: RGBA((0, 0, 0, 0)),
        hovered_border_color:  RGBA((0, 0, 0, 0)),
        border_width:          0.0,
        border_radius:         (0.0, 0.0, 0.0, 0.0),
    ),

    footer:
    (
        show:             false,
        show_hint:        false,
        hint_text:        "",
        show_count:       false,
        count_format:     "{shown} / {total}",
        single_format:    "{total}",
        text_size:        10,
        text_color:       RGB((60, 60, 60)),
        hint_color:       RGB((60, 60, 60)),
        count_color:      RGB((150, 150, 150)),
        font_weight:      Normal,
        font_style:       Normal,
        top_margin:       4.0,
        padding:          (0, 0, 0, 0),
        background_color: RGBA((0, 0, 0, 0)),
        border_color:     RGBA((0, 0, 0, 0)),
        border_width:     0.0,
        border_radius:    (0.0, 0.0, 0.0, 0.0),
        position:         Bottom,
        text_orientation: Horizontal,
        width:            0,
        height:           0,
    ),

    behaviour:
    (
        search_name:        true,
        search_comment:     true,
        search_exec:        false,
        search_keywords:    true,
        case_sensitive:     false,
        close_on_launch:    true,
        terminal_command:   "",
        calc_enabled:           true,
        copy_feedback_text:     "[ copied ]",
        copy_feedback_seconds:  2.0,
        min_query_length:       0,
        show_on_empty_query:    true,
        max_empty_results:      0,
    ),

    keybinds:
    (
        close:              ["Escape"],
        select_up:          ["ArrowUp"],
        select_down:        ["ArrowDown"],
        select_left:        ["ArrowLeft"],
        select_right:       ["ArrowRight", "Tab"],
        launch_alt_prefix:  "Alt",
        relaunch_key:       "l",
    ),

    background_images: [],
)

