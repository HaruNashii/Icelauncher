// ╭─────────────────────────────────────────────────────────────────────────╮
// │   E V E R F O R E S T   ·   ICELAUNCHER                                 │
// │   Ultra-thin top bar. Single column. Forest floor quiet.                │
// ╰─────────────────────────────────────────────────────────────────────────╯
//
//  PALETTE — Everforest Dark Medium
//    bg0 (42,45,43)  bg1 (53,58,54)  bg2 (64,71,65)  bg3 (75,82,76)
//    fg (211,198,170)  grey (147,164,153)
//    red (230,126,128)  orange (230,152,98)  yellow (219,188,127)
//    green (167,192,128) ← PRIMARY  aqua (131,192,179)  purple (210,166,215)
//
//  LAYOUT — COMPACT TOP, SINGLE COLUMN
//    · 480×520 — taller than wide, compact portrait launcher.
//    · TopRight anchor — appears near the top right like a dropdown.
//    · 1 column, no grid. Pure list.
//    · 0px border radius — flat like the icebar's everforest.
//    · Search at Top. No footer (ultra minimal).

LauncherConfig
(
    window:
    (
        width:              480,
        height:             520,
        max_results:        14,
        padding:            10,
        section_spacing:    0,
        entry_spacing:      1,
        grid_side_items:    1,
        grid_column_spacing: 0,

        border_radius:      (0.0, 0.0, 0.0, 0.0),
        border_width:       0.0,
        border_color:       RGBA((0, 0, 0, 0)),
        background_color:   RGBA((42, 45, 43, 100)),
        background_gradient: None,

        shadow_color:       RGBA((0, 0, 0, 0)),
        shadow_offset_x:    0.0,
        shadow_offset_y:    0.0,
        shadow_blur:        0.0,

        anchor:             TopRight,
        margin_top:         24,
        margin_bottom:      0,
        margin_left:        0,
        margin_right:       0,
    ),

    scrollbar:
    (
        show:                    true,
        width:                   4,
        margin:                  1,
        scroller_width:          4,
        border_radius:           (0.0, 0.0, 0.0, 0.0),
        rail_color:              RGBA((0, 0, 0, 0)),
        rail_border_color:       RGBA((0, 0, 0, 0)),
        rail_border_width:       0.0,
        scroller_color:          RGBA((167, 192, 128, 40)),
        scroller_hovered_color:  RGBA((167, 192, 128, 65)),
        scroller_dragging_color: RGBA((167, 192, 128, 85)),
        scroller_border_color:   RGBA((0, 0, 0, 0)),
        scroller_border_width:   0.0,
    ),

    search:
    (
        placeholder:               "search...",
        text_size:                 13,
        input_padding:             8,
        bottom_margin:             6.0,

        background_color:          RGB((53, 58, 54)),
        background_gradient:       None,
        focused_background_color:  RGB((53, 58, 54)),
        focused_background_gradient: None,
        border_color:              RGBA((0, 0, 0, 0)),
        focused_border_color:      RGB((167, 192, 128)),
        border_width:              1.0,
        border_radius:             (0.0, 0.0, 0.0, 0.0),

        text_color:                RGB((211, 198, 170)),
        placeholder_color:         RGB((87, 95, 87)),
        selection_color:           RGBA((167, 192, 128, 40)),

        icon:                      "",
        icon_color:                RGB((87, 95, 87)),

        font_weight:               Normal,
        font_style:                Normal,
        font_family:               "",

        position:                  Top,
        orientation:               Horizontal,
        width:                     0,
        height:                    0,
        fixed_x:                   None,
        fixed_y:                   None,
    ),

    entry:
    (
        name_size:              13,
        name_color:             RGB((211, 198, 170)),
        selected_name_color:    RGB((211, 198, 170)),
        hovered_name_color:     RGB((167, 192, 128)),
        name_font_weight:       Normal,
        name_font_style:        Normal,
        name_font_family:       "",
        name_align:             Left,
        name_max_chars:         50,

        comment_size:           10,
        comment_color:          RGB((87, 95, 87)),
        selected_comment_color: RGB((131, 192, 179)),
        hovered_comment_color:  RGB((87, 95, 87)),
        comment_font_weight:    Normal,
        comment_font_style:     Normal,
        comment_font_family:    "",
        comment_align:          Left,
        comment_max_chars:      50,
        show_comment:           true,
        name_comment_spacing:   1,

        padding:                (4, 8, 4, 8),
        label_position:         Right,
        width:                  0,
        height:                 0,

        background_color:       RGBA((0, 0, 0, 0)),
        hovered_color:          RGB((53, 58, 54)),
        pressed_color:          RGB((42, 45, 43)),
        selected_color:         RGBA((167, 192, 128, 15)),
        selected_hovered_color: RGBA((167, 192, 128, 30)),
        text_color:             RGB((211, 198, 170)),

        border_color:           RGBA((0, 0, 0, 0)),
        selected_border_color:  RGBA((167, 192, 128, 40)),
        hovered_border_color:   RGBA((0, 0, 0, 0)),
        pressed_border_color:   RGBA((0, 0, 0, 0)),
        border_width:           1.0,
        border_radius:          (0.0, 0.0, 0.0, 0.0),

        shadow_color:               RGBA((0, 0, 0, 0)),
        shadow_offset_x:            0.0,
        shadow_offset_y:            0.0,
        shadow_blur:                0.0,
        selected_shadow_color:      RGBA((0, 0, 0, 0)),
        selected_shadow_offset_x:   0.0,
        selected_shadow_offset_y:   0.0,
        selected_shadow_blur:       0.0,
        hovered_shadow_color:       RGBA((0, 0, 0, 0)),
        hovered_shadow_offset_x:    0.0,
        hovered_shadow_offset_y:    0.0,
        hovered_shadow_blur:        0.0,

        wrap_word:                      false,
        ellipsize_instead_of_wrapping:   true,
        ellipsis:                       "...",

        show_separator:     false,
        separator_color:    RGBA((53, 58, 54, 80)),
        separator_width:    1.0,

	hot_apps_color:     RGBA((167, 192, 128, 40)),

    ),

    icon:
    (
        show:                  true,
        use_real_icons:        true,
        width:                 28,
        height:                28,
        text_size:             14,
        gap:                   8,
        padding:               (0, 0),
        opacity:               0.85,
        selected_opacity:      1.0,
        hovered_opacity:       1.0,

        background_color:      RGBA((53, 58, 54, 80)),
        hovered_color:         RGBA((64, 71, 65, 80)),
        selected_color:        RGBA((167, 192, 128, 30)),
        icon_color:            RGB((131, 192, 179)),
        selected_icon_color:   RGB((255, 255, 255)),
        hovered_icon_color:    RGB((167, 192, 128)),

        border_color:          RGBA((0, 0, 0, 0)),
        selected_border_color: RGBA((167, 192, 128, 50)),
        hovered_border_color:  RGBA((0, 0, 0, 0)),
        border_width:          0.0,
        border_radius:         (4.0, 4.0, 4.0, 4.0),
    ),

    footer:
    (
        show:             false,
        show_hint:        false,
        hint_text:        "",
        show_count:       false,
        count_format:     "{shown} / {total}",
        single_format:    "{total}",
        text_size:        11,
        text_color:       RGB((87, 95, 87)),
        hint_color:       RGB((87, 95, 87)),
        count_color:      RGB((167, 192, 128)),
        font_weight:      Normal,
        font_style:       Normal,
        top_margin:       4.0,
        padding:          (0, 0, 0, 0),
        background_color: RGBA((0, 0, 0, 0)),
        border_color:     RGBA((0, 0, 0, 0)),
        border_width:     0.0,
        border_radius:    (0.0, 0.0, 0.0, 0.0),
        position:         Bottom,
        text_orientation: Horizontal,
        width:            0,
        height:           0,
    ),

    behaviour:
    (
        search_name:        true,
        search_comment:     true,
        search_exec:        false,
        search_keywords:    true,
        case_sensitive:     false,
        close_on_launch:    true,
        terminal_command:   "",
        calc_enabled:           true,
        copy_feedback_text:     "Copied!",
        copy_feedback_seconds:  2.0,
        min_query_length:       0,
        show_on_empty_query:    true,
        max_empty_results:      0,
    ),

    keybinds:
    (
        close:              ["Escape"],
        select_up:          ["ArrowUp"],
        select_down:        ["ArrowDown"],
        select_left:        ["ArrowLeft"],
        select_right:       ["ArrowRight", "Tab"],
        launch_alt_prefix:  "Alt",
        relaunch_key:       "l",
    ),

    background_images: [],
)

