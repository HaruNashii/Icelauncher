// ╭─────────────────────────────────────────────────────────────────────────╮
// │                                                                         │
// │   R O S E   P I N É   D A W N   ·   ICELAUNCHER                        │
// │   Warm daylight. Gentle list. Top-right search. Soft rose accents.      │
// │                                                                         │
// ╰─────────────────────────────────────────────────────────────────────────╯
//
//  PALETTE — Rosé Pine Dawn
//
//    base        (250, 244, 237)  ← window background (cream)
//    surface     (255, 250, 243)  ← entry bg (lighter cream)
//    overlay     (242, 233, 222)  ← hover
//    muted       (152, 147, 165)  ← muted text / placeholder
//    subtle      (121, 117, 147)  ← comment text
//    text        ( 87,  82, 121)  ← primary text
//    love        (180,  99, 122)  ← red-pink accent (selected, search border)
//    gold        (234, 157,  52)  ← gold (icon glyph, count)
//    rose        (215, 130, 126)  ← secondary accent (hover)
//    pine        ( 40, 105, 131)  ← teal (icon selected)
//    foam        ( 86, 148, 159)  ← teal-green (scrollbar)
//    iris        (144, 122, 169)  ← purple (border)
//    highlight   (212, 202, 228)  ← subtle selection bg
//
//  DESIGN:
//    · Classic list (grid_side_items: 1) — airy, spacious entries
//    · Search pinned to TOP-RIGHT corner — elegant asymmetry
//    · Light window (cream background) — the only light theme here
//    · 16px radius — soft, pillow-like corners
//    · Love (rose-pink) is the primary accent — warm and decisive
//    · Gold icon glyphs — sunrise warmth
//    · Footer hidden — the dawn is quiet

LauncherConfig
(

    // ─────────────────────────────────────────────────────────────────────────
    //  WINDOW
    // ─────────────────────────────────────────────────────────────────────────
    window:
    (
        width:              520,
        height:             460,
        max_results:        10,
        padding:            16,
        section_spacing:    8,
        entry_spacing:      4,
        grid_side_items:    1,

        border_radius:      (16.0, 16.0, 16.0, 16.0),
        border_width:       1.0,
        border_color:       RGB((212, 202, 228)),
        background_color:   RGBA((250, 244, 237, 98)),

        shadow_color:       RGBA((87, 82, 121, 20)),
        shadow_offset_x:    0.0,
        shadow_offset_y:    8.0,
        shadow_blur:        28.0,
    ),


    // ─────────────────────────────────────────────────────────────────────────
    //  SCROLLBAR
    // ─────────────────────────────────────────────────────────────────────────
    scrollbar:
    (
        show:                   true,
        width:                  4,
        margin:                 3,
        scroller_width:         4,
        border_radius:          (2.0, 2.0, 2.0, 2.0),

        rail_color:             RGBA((0, 0, 0, 0)),
        rail_border_color:      RGBA((0, 0, 0, 0)),
        rail_border_width:      0.0,

        scroller_color:         RGBA((86, 148, 159, 50)),
        scroller_border_color:  RGBA((0, 0, 0, 0)),
        scroller_border_width:  0.0,
    ),


    // ─────────────────────────────────────────────────────────────────────────
    //  SEARCH BAR
    // ─────────────────────────────────────────────────────────────────────────
    search:
    (
        placeholder:        "Find an app...",
        text_size:          15,
        input_padding:      11,
        bottom_margin:      10.0,

        background_color:   RGB((255, 250, 243)),
        border_color:       RGB((180, 99, 122)),
        border_width:       1.5,
        border_radius:      (10.0, 10.0, 10.0, 10.0),

        text_color:         RGB((87, 82, 121)),
        placeholder_color:  RGB((152, 147, 165)),
        selection_color:    RGB((180, 99, 122)),

        position:           TopRight,
        orientation:        Horizontal,
        width:              260,
        height:             0,
        fixed_x:            None,
        fixed_y:            None,
    ),


    // ─────────────────────────────────────────────────────────────────────────
    //  RESULT ENTRIES
    // ─────────────────────────────────────────────────────────────────────────
    entry:
    (
        name_size:              14,
        name_color:             RGB((87, 82, 121)),

        comment_size:           11,
        comment_color:          RGB((121, 117, 147)),
        comment_max_chars:      55,
        show_comment:           true,

        padding:                (8, 12),

        background_color:       RGBA((255, 250, 243, 70)),
        hovered_color:          RGB((242, 233, 222)),
        pressed_color:          RGB((212, 202, 228)),
        selected_color:         RGBA((180, 99, 122, 10)),
        selected_hovered_color: RGBA((215, 130, 126, 30)),
        text_color:             RGB((87, 82, 121)),

        border_color:           RGBA((212, 202, 228, 80)),
        selected_border_color:  RGB((180, 99, 122)),
        border_width:           1.0,
        border_radius:          (10.0, 10.0, 10.0, 10.0),

        shadow_color:           RGBA((87, 82, 121, 8)),
        shadow_offset_x:        0.0,
        shadow_offset_y:        2.0,
        shadow_blur:            6.0,

        width:                  0,
        height:                 0,
    ),


    // ─────────────────────────────────────────────────────────────────────────
    //  ICON BADGE
    // ─────────────────────────────────────────────────────────────────────────
    icon:
    (
        show:               true,
        use_real_icons:     false,
        width:              32,
        height:             32,
        text_size:          16,
        gap:                12,

        background_color:   RGB((255, 250, 243)),
        selected_color:     RGB((40, 105, 131)),
        icon_color:         RGB((234, 157, 52)),

        border_color:       RGB((212, 202, 228)),
        border_width:       1.0,
        border_radius:      (8.0, 8.0, 8.0, 8.0),
    ),


    // ─────────────────────────────────────────────────────────────────────────
    //  FOOTER
    // ─────────────────────────────────────────────────────────────────────────
    footer:
    (
        show:           false,
        show_hint:      false,
        hint_text:      "",
        show_count:     false,
        text_size:      11,
        text_color:     RGB((152, 147, 165)),
        top_margin:     0.0,
        position:       Bottom,
        text_orientation: Horizontal,
        width:          0,
        height:         0,
    ),


    // ─────────────────────────────────────────────────────────────────────────
    //  SEARCH BEHAVIOUR
    // ─────────────────────────────────────────────────────────────────────────
    behaviour:
    (
        search_name:        true,
        search_comment:     true,
        search_exec:        false,
        search_keywords:    true,
        case_sensitive:     false,
        close_on_launch:    true,
        terminal_command:   "",
        calc_enabled:           true,
        copy_feedback_text:     "Copied!",
        copy_feedback_seconds:  2.0,
    ),

    background_images: [],
)
